# GitHub Trending Wiki 配置
# 复制为 .env 并按需修改

# 代理配置（sing-box）
GITHUB_TRENDING_PROXY=http://127.0.0.1:7890

# GitHub Trending URL
GITHUB_TRENDING_URL=https://github.com/trending

# 项目根目录
GITHUB_TRENDING_WIKI_PATH=/srv/www/github-trending-wiki

# 采集配置
GITHUB_TRENDING_MAX_RETRIES=3
GITHUB_TRENDING_RETRY_DELAY=5
GITHUB_TRENDING_TIMEOUT=30
GITHUB_TRENDING_MIN_PROJECTS=5

# 飞书推送配置
GITHUB_TRENDING_FEISHU_CHAT_ID=oc_b269ff6fab6e321a35e344ea5984e985
